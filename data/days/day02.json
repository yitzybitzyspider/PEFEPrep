      "type": "MCQ",
      "concept": "Hydrostatic pressure",
      "stem": "The gauge pressure at the bottom of a 6.0 m deep, open tank of water is most nearly:",
      "equations": [
        "$p = \\gamma h = \\rho g h$"
      ],
      "options": [
        "5.89 kPa",
        "58.9 kPa",
        "588 kPa",
        "58.9 Pa"
      ],
      "answer": 1,
      "solution": "$p = \\rho g h = (1000)(9.81)(6.0) = 58{,}860\\ \\mathrm{Pa} \\approx 58.9\\ \\mathrm{kPa}$.",
      "handbook": "Fluid Mechanics — Pressure in a static liquid",
      "references": "Ctrl-F: Specific Weight"
    },
