  "topic": "Hydraulics",
  "questions": [
    { "id": "D4-Q01", "set": "A", "type": "MCQ", "concept": "Hydraulic radius (rectangular)",
      "stem": "A rectangular open channel is 3 m wide and carries water at a flow depth of 1 m. The hydraulic radius $R_H$ is most nearly:",
      "equations": ["$R_H = \\dfrac{A}{P},\\quad A = by,\\ P = b+2y$"],
      "options": ["0.50 m", "0.60 m", "1.00 m", "3.00 m"], "answer": 1,
      "solution": "$A = 3(1) = 3\\ \\mathrm{m^2};\\ P = 3+2(1) = 5\\ \\mathrm{m};\\ R_H = 3/5 = 0.60\\ \\mathrm{m}$.",
      "handbook": "Flow in Noncircular Conduits (p. 188)", "references": "Ctrl-F: Hydraulic Radius" },

    { "id": "D4-Q02", "set": "A", "type": "MCQ", "concept": "Hydraulic radius (full pipe)",
      "stem": "A circular storm sewer of diameter D flows completely full. Its hydraulic radius equals:",
      "equations": ["$R_H = \\dfrac{A}{P} = \\dfrac{\\pi D^{2}/4}{\\pi D}$"],
      "options": ["D/2", "D", "D/4", "D/8"], "answer": 2,
      "solution": "$R_H = \\dfrac{\\pi D^{2}/4}{\\pi D} = \\dfrac{D}{4}$.",
      "handbook": "Flow in Noncircular Conduits (p. 188)", "references": "Ctrl-F: Hydraulic Radius" },

    { "id": "D4-Q03", "set": "A", "type": "MCQ", "concept": "Manning velocity (SI)",
      "stem": "A rectangular channel (b = 3 m, y = 1 m) has n = 0.013 and bed slope S = 0.001. The uniform-flow velocity (SI Manning) is most nearly:",
      "equations": ["$v = \\dfrac{K}{n}R_H^{2/3}S^{1/2},\\quad K = 1.0\\ (\\text{SI})$"],
      "options": ["0.86 m/s", "1.20 m/s", "1.73 m/s", "2.05 m/s"], "answer": 2,
      "solution": "$R_H = 0.60\\ \\mathrm{m};\\ v = \\dfrac{1.0}{0.013}(0.60)^{2/3}(0.001)^{1/2} = 76.9(0.711)(0.0316) = 1.73\\ \\mathrm{m/s}$.",
      "handbook": "Manning's Equation (p. 303)", "references": "Ctrl-F: Manning" },

    { "id": "D4-Q04", "set": "A", "type": "MCQ", "concept": "Manning discharge (SI)",
      "stem": "A rectangular channel 4 m wide flows 1.5 m deep with n = 0.015 and S = 0.0009. The discharge (SI Manning) is most nearly:",
      "equations": ["$Q = \\dfrac{K}{n}A\\,R_H^{2/3}S^{1/2}$"],
      "options": ["6.5 m³/s", "8.9 m³/s", "13.4 m³/s", "10.8 m³/s"], "answer": 3,
      "solution": "$A = 6\\ \\mathrm{m^2},\\ P = 7\\ \\mathrm{m},\\ R_H = 0.857\\ \\mathrm{m}$. $v = \\dfrac{1.0}{0.015}(0.857)^{2/3}(0.0009)^{1/2} = 1.80\\ \\mathrm{m/s};\\ Q = 1.80(6) = 10.8\\ \\mathrm{m^3/s}$.",
      "handbook": "Manning's Equation (p. 303)", "references": "Ctrl-F: Manning" },

    { "id": "D4-Q05", "set": "A", "type": "MCQ", "concept": "Manning constant K",
      "stem": "In Manning's equation, the unit constant K for USCS units is:",
      "equations": ["$K = 1.486\\ (\\text{USCS}),\\ 1.0\\ (\\text{SI})$"],
      "options": ["1.0", "1.318", "1.486", "0.849"], "answer": 2,
      "solution": "By definition, $K = 1.486$ for USCS units and $1.0$ for SI units.",
      "handbook": "Manning's Equation (p. 303)", "references": "Ctrl-F: Manning" },

    { "id": "D4-Q06", "set": "A", "type": "MCQ", "concept": "Effect of roughness n",
      "stem": "Holding discharge, geometry, and slope constant, increasing the roughness coefficient n causes the uniform-flow velocity to:",
      "equations": ["$v = \\dfrac{K}{n}R_H^{2/3}S^{1/2}\\ \\Rightarrow\\ v \\propto \\dfrac{1}{n}$"],
      "options": ["increase", "decrease", "stay the same", "double"], "answer": 1,
      "solution": "$v \\propto 1/n$, so larger $n$ decreases velocity.",
      "handbook": "Manning's Equation (p. 303)", "references": "Ctrl-F: Manning" },

    { "id": "D4-Q07", "set": "A", "type": "MCQ", "concept": "Specific energy",
      "stem": "A rectangular channel carries a unit discharge q = 2.5 m²/s at a depth of 1.5 m. The specific energy (α = 1.0) is most nearly:",
      "equations": ["$E = y + \\dfrac{v^{2}}{2g},\\quad v = q/y$"],
      "options": ["1.64 m", "1.50 m", "1.78 m", "2.00 m"], "answer": 0,
      "solution": "$v = 2.5/1.5 = 1.667\\ \\mathrm{m/s};\\ E = 1.5 + \\dfrac{1.667^{2}}{2(9.81)} = 1.5+0.142 = 1.64\\ \\mathrm{m}$.",
      "handbook": "Specific Energy (p. 302)", "references": "Ctrl-F: Specific Energy" },

    { "id": "D4-Q08", "set": "A", "type": "MCQ", "concept": "Critical depth (rectangular)",
      "stem": "A rectangular channel 4 m wide carries Q = 10 m³/s. The critical depth is most nearly:",
      "equations": ["$y_c = \\left(\\dfrac{q^{2}}{g}\\right)^{1/3},\\quad q = Q/B$"],
      "options": ["0.61 m", "1.10 m", "0.86 m", "1.25 m"], "answer": 2,
      "solution": "$q = 10/4 = 2.5\\ \\mathrm{m^2/s};\\ y_c = \\left(\\dfrac{2.5^{2}}{9.81}\\right)^{1/3} = (0.637)^{1/3} = 0.86\\ \\mathrm{m}$.",
      "handbook": "Critical Depth (p. 301)", "references": "Ctrl-F: Critical Depth" },

    { "id": "D4-Q09", "set": "A", "type": "MCQ", "concept": "Critical flow condition",
      "stem": "At critical flow in an open channel:",
      "equations": ["At $y_c$: $E$ minimum, $Fr = 1$"],
      "options": ["specific energy is maximum and Fr = 0", "specific energy is minimum and Fr = 1", "the velocity is zero", "the depth is maximum"], "answer": 1,
      "solution": "Critical flow is the state of minimum specific energy for a given discharge, where $Fr = 1$.",
      "handbook": "Critical Depth; Froude number (p. 301)", "references": "Ctrl-F: Critical Depth" },

    { "id": "D4-Q10", "set": "A", "type": "MCQ", "concept": "Froude number + regime",
      "stem": "Water flows 0.5 m deep at 3 m/s in a wide rectangular channel. The Froude number and regime are most nearly:",
      "equations": ["$Fr = \\dfrac{v}{\\sqrt{g\\,y}}$"],
      "options": ["0.74, subcritical", "1.35, supercritical", "1.35, subcritical", "0.74, supercritical"], "answer": 1,
      "solution": "$Fr = \\dfrac{3}{\\sqrt{9.81(0.5)}} = \\dfrac{3}{2.215} = 1.35 > 1 \\Rightarrow$ supercritical.",
      "handbook": "Froude number (p. 302)", "references": "Ctrl-F: Froude Number" },

    { "id": "D4-Q11", "set": "A", "type": "MCQ", "concept": "Regime classification",
      "stem": "A flow with a Froude number of 0.6 is classified as:",
      "equations": ["$Fr < 1$: subcritical"],
      "options": ["supercritical", "critical", "subcritical", "turbulent"], "answer": 2,
      "solution": "$Fr = 0.6 < 1$, so the flow is subcritical.",
      "handbook": "Froude number (p. 302)", "references": "Ctrl-F: Froude Number" },

    { "id": "D4-Q12", "set": "A", "type": "MCQ", "concept": "Alternate depths",
      "stem": "“Alternate depths” are two different flow depths that share the same:",
      "equations": ["Same $E$, same $Q$ (one sub-, one supercritical)"],
      "options": ["discharge only", "specific energy", "momentum", "velocity"], "answer": 1,
      "solution": "Alternate depths are the two depths (one sub-, one supercritical) that yield the same specific energy for a given Q.",
      "handbook": "Specific Energy Diagram (p. 302)", "references": "Ctrl-F: Specific Energy" },

    { "id": "D4-Q13", "set": "A", "type": "MCQ", "concept": "Hydraulic jump depth",
      "stem": "A hydraulic jump forms where the upstream depth is 0.4 m and Fr₁ = 2.5. The downstream (sequent) depth is most nearly:",
      "equations": ["$y_2 = \\dfrac{y_1}{2}\\left(-1+\\sqrt{1+8Fr_1^{2}}\\right)$"],
      "options": ["0.80 m", "1.00 m", "1.23 m", "1.60 m"], "answer": 2,
      "solution": "$y_2 = \\dfrac{0.4}{2}\\left(-1+\\sqrt{1+8(2.5)^{2}}\\right) = 0.2(-1+\\sqrt{51}) = 0.2(6.141) = 1.23\\ \\mathrm{m}$.",
      "handbook": "Hydraulic Jump (p. 303)", "references": "Ctrl-F: Hydraulic Jump" },

    { "id": "D4-Q14", "set": "A", "type": "MCQ", "concept": "Hydraulic jump nature",
      "stem": "A hydraulic jump occurs when flow transitions from:",
      "equations": ["supercritical → subcritical (dissipates energy)"],
      "options": ["subcritical to supercritical, gaining energy", "supercritical to subcritical, dissipating energy", "laminar to turbulent flow", "uniform to nonuniform with no energy loss"], "answer": 1,
      "solution": "A hydraulic jump is a sudden supercritical-to-subcritical transition that dissipates mechanical energy.",
      "handbook": "Hydraulic Jump (p. 303)", "references": "Ctrl-F: Hydraulic Jump" },

    { "id": "D4-Q15", "set": "A", "type": "MCQ", "concept": "Rectangular weir (USCS)",
      "stem": "A suppressed rectangular weir 5 ft long discharges under a head of 1 ft (C = 3.33, USCS). The discharge is most nearly:",
      "equations": ["$Q = CLH^{3/2}$"],
      "options": ["11.1 cfs", "22.0 cfs", "33.3 cfs", "16.7 cfs"], "answer": 3,
      "solution": "$Q = 3.33(5)(1)^{3/2} = 16.7\\ \\mathrm{cfs}$.",
      "handbook": "Weir Formulas (p. 303)", "references": "Ctrl-F: Weir" },

    { "id": "D4-Q16", "set": "A", "type": "MCQ", "concept": "V-notch weir (USCS)",
      "stem": "A 90° V-notch weir operates under a head of 0.8 ft (C = 2.54, USCS). The discharge is most nearly:",
      "equations": ["$Q = CH^{5/2}$"],
      "options": ["0.91 cfs", "2.03 cfs", "1.45 cfs", "2.54 cfs"], "answer": 2,
      "solution": "$Q = 2.54(0.8)^{5/2} = 2.54(0.572) = 1.45\\ \\mathrm{cfs}$.",
      "handbook": "Weir Formulas (p. 303)", "references": "Ctrl-F: Weir" },

    { "id": "D4-Q17", "set": "A", "type": "Numeric", "concept": "Rectangular weir (SI)",
      "stem": "A suppressed rectangular weir 2 m long operates under a head of 0.3 m. Using the SI weir coefficient C = 1.84, determine the discharge Q (in m³/s).",
      "equations": ["$Q = CLH^{3/2}$"],
      "answer": "0.60 m³/s",
      "solution": "$Q = 1.84(2)(0.3)^{3/2} = 1.84(2)(0.164) = 0.60\\ \\mathrm{m^3/s}$.",
      "handbook": "Weir Formulas (p. 303)", "references": "Ctrl-F: Weir" },

    { "id": "D4-Q18", "set": "A", "type": "MCQ", "concept": "Contracted weir formula",
      "stem": "The discharge over a contracted rectangular weir is given by:",
      "equations": ["$Q = C(L - 0.2H)H^{3/2}$"],
      "options": ["$Q = CLH^{3/2}$", "$Q = C(L − 0.2H)H^{3/2}$", "$Q = CH^{5/2}$", "$Q = CA\\sqrt{2gh}$"], "answer": 1,
      "solution": "End contractions shorten the effective crest, giving $Q = C(L-0.2H)H^{3/2}$.",
      "handbook": "Weir Formulas (p. 303)", "references": "Ctrl-F: Weir" },

    { "id": "D4-Q19", "set": "A", "type": "MCQ", "concept": "Orifice free discharge",
      "stem": "A sharp-edged orifice (d = 0.10 m, C = 0.61) discharges freely with 2 m of head above its center. The discharge is most nearly:",
      "equations": ["$Q = CA_0\\sqrt{2gh},\\quad A_0 = \\dfrac{\\pi}{4}d^{2}$"],
      "options": ["0.015 m³/s", "0.049 m³/s", "0.060 m³/s", "0.030 m³/s"], "answer": 3,
      "solution": "$A_0 = \\dfrac{\\pi}{4}(0.10)^{2} = 7.85\\times10^{-3}\\ \\mathrm{m^2};\\ Q = 0.61(7.85\\times10^{-3})\\sqrt{2(9.81)(2)} = 0.030\\ \\mathrm{m^3/s}$.",
      "handbook": "Orifice Discharging Freely into Atmosphere (p. 190)", "references": "Ctrl-F: Orifice" },

    { "id": "D4-Q20", "set": "A", "type": "MCQ", "concept": "Submerged orifice",
      "stem": "A submerged orifice (A = 0.05 m², C = 0.61) operates under a 1.5 m difference between the upstream and downstream water surfaces. The discharge is most nearly:",
      "equations": ["$Q = CA\\sqrt{2g(h_1-h_2)}$"],
      "options": ["0.165 m³/s", "0.083 m³/s", "0.117 m³/s", "0.235 m³/s"], "answer": 0,
      "solution": "$Q = 0.61(0.05)\\sqrt{2(9.81)(1.5)} = 0.165\\ \\mathrm{m^3/s}$.",
      "handbook": "Submerged Orifice (Steady-Flow) (p. 190)", "references": "Ctrl-F: Orifice" },

    { "id": "D4-Q21", "set": "A", "type": "Numeric", "concept": "Tank draining time",
      "stem": "A cylindrical tank 2 m in diameter drains through an orifice of area 0.01 m² in its base. Using the Handbook tank-draining relation (no discharge coefficient), find the time (in seconds) for the water level to fall from 4 m to 1 m above the orifice.",
      "equations": ["$\\Delta t = \\dfrac{2(A_t/A_0)}{\\sqrt{2g}}\\left(h_1^{1/2}-h_2^{1/2}\\right)$"],
      "answer": "≈ 142 s",
      "solution": "$A_t = \\dfrac{\\pi}{4}(2)^{2} = 3.142\\ \\mathrm{m^2};\\ \\Delta t = \\dfrac{2(3.142/0.01)}{\\sqrt{2(9.81)}}(\\sqrt{4}-\\sqrt{1}) = \\dfrac{628.3}{4.429}(1) = 142\\ \\mathrm{s}$.",
      "handbook": "Orifice Discharging Freely (time to drain a tank) (p. 190)", "references": "Ctrl-F: Drain" },

    { "id": "D4-Q22", "set": "A", "type": "MCQ", "concept": "Blower power",
      "stem": "A blower moves air (W = 2 lb/sec, R = 53.3 ft-lbf/lb-°R) at an inlet temperature of 530 °R from P₁ = 14.7 psia to P₂ = 18.7 psia at efficiency e = 0.80. Using the Handbook blower equation (C = 550, n = 0.283), the power requirement is most nearly:",
      "equations": ["$P_w = \\dfrac{W R T_1}{C\\,n\\,e}\\left[\\left(\\dfrac{P_2}{P_1}\\right)^{0.283}-1\\right]$"],
      "options": ["18 hp", "32 hp", "25 hp", "45 hp"], "answer": 1,
      "solution": "$P_w = \\dfrac{2(53.3)(530)}{550(0.283)(0.80)}\\left[\\left(\\dfrac{18.7}{14.7}\\right)^{0.283}-1\\right] = 453.7(0.0705) = 32\\ \\mathrm{hp}$.",
      "handbook": "Blowers (p. 198)", "references": "Ctrl-F: Blowers" },

    { "id": "D4-Q23", "set": "A", "type": "MCQ", "concept": "Partial-flow sewer",
      "stem": "According to the Handbook's hydraulic-element (partial-flow) graph for circular sewers, the maximum discharge in a circular pipe occurs at a relative depth d/D of approximately:",
      "equations": ["$Q_{max}$ at $d/D \\approx 0.93$"],
      "options": ["0.50", "0.71", "0.93", "1.00"], "answer": 2,
      "solution": "From the hydraulic-element graph, $Q/Q_f$ peaks at $d/D \\approx 0.93$ (slightly above the full-flow value), not at d/D = 1.0.",
      "handbook": "Hydraulic-Element (Partial Flow) Graph for Circular Sewers (p. 301)", "references": "Ctrl-F: Hydraulic Elements" },

    { "id": "D4-Q24", "set": "A", "type": "MCQ", "concept": "Trapezoidal Manning",
      "stem": "A trapezoidal channel has bottom width 3 m, side slopes 2H:1V (z = 2), and flows 1 m deep with n = 0.025 and S = 0.0016. The discharge (SI Manning) is most nearly:",
      "equations": ["$A=(b+zy)y,\\ P=b+2y\\sqrt{1+z^{2}},\\ Q=\\dfrac{K}{n}A R_H^{2/3}S^{1/2}$"],
      "options": ["4.3 m³/s", "6.1 m³/s", "7.8 m³/s", "9.5 m³/s"], "answer": 1,
      "solution": "$A = (3+2)(1) = 5\\ \\mathrm{m^2};\\ P = 3+2\\sqrt{5} = 7.47\\ \\mathrm{m};\\ R_H = 0.669\\ \\mathrm{m}$. $v = \\dfrac{1.0}{0.025}(0.669)^{2/3}(0.0016)^{1/2} = 1.22\\ \\mathrm{m/s};\\ Q = 1.22(5) = 6.1\\ \\mathrm{m^3/s}$.",
      "handbook": "Manning's Equation (p. 303)", "references": "Ctrl-F: Manning" }
  ]
}
