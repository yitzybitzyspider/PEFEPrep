  "questions": [
    { "id": "D1-Q01", "set": "A", "type": "MCQ", "concept": "Quadratic equation",
      "stem": "Solve 2x² − 5x − 3 = 0.",
      "equations": ["$x = \\dfrac{-b \\pm \\sqrt{b^{2}-4ac}}{2a}$"],
      "options": ["x = 3, −1/2", "x = −3, 1/2", "x = 2, −3", "x = 1, 3/2"], "answer": 0,
      "solution": "$x = \\dfrac{5 \\pm \\sqrt{25+24}}{4} = \\dfrac{5 \\pm 7}{4} = 3\\ \\text{or}\\ -0.5$.",
      "handbook": "Mathematics — Quadratic Equation", "references": "Ctrl-F: Quadratic" },

    { "id": "D1-Q02", "set": "A", "type": "MCQ", "concept": "Exponents / logarithms",
      "stem": "If 3ˣ = 81, then x =",
      "equations": ["$x = \\dfrac{\\log 81}{\\log 3}$"],
      "options": ["3", "4", "27", "3.3"], "answer": 1,
      "solution": "$81 = 3^{4}$, so $x = 4$.",
      "handbook": "Mathematics — Logarithms", "references": "Ctrl-F: Logarithm" },

    { "id": "D1-Q03", "set": "A", "type": "MCQ", "concept": "Simultaneous linear equations",
      "stem": "Solve the system 2x + 3y = 12 and x − y = 1.",
      "equations": ["Substitute $x = 1 + y$"],
      "options": ["(3, 2)", "(2, 3)", "(4, 1)", "(1, 4)"], "answer": 0,
      "solution": "$x = 1+y$; $2(1+y)+3y = 12 \\Rightarrow 2+5y = 12 \\Rightarrow y = 2,\\ x = 3$.",
      "handbook": "Algebra — simultaneous equations", "references": "Ctrl-F: Simultaneous" },

    { "id": "D1-Q04", "set": "A", "type": "MCQ", "concept": "Right-triangle trig",
      "stem": "In a 3–4–5 right triangle, the angle opposite the side of length 3 is closest to:",
      "equations": ["$\\tan\\theta = \\dfrac{\\text{opp}}{\\text{adj}}$"],
      "options": ["30°", "36.9°", "45°", "53.1°"], "answer": 1,
      "solution": "$\\tan\\theta = \\dfrac{3}{4},\\ \\theta = \\arctan(0.75) = 36.9°$.",
      "handbook": "Trigonometry — right-triangle relations", "references": "Ctrl-F: Trigonometric" },

    { "id": "D1-Q05", "set": "A", "type": "MCQ", "concept": "Common-angle trig",
      "stem": "Evaluate sin 30° + cos 60°.",
      "equations": ["$\\sin 30° = \\cos 60° = 0.5$"],
      "options": ["0.50", "0.87", "1.00", "1.50"], "answer": 2,
      "solution": "$0.5 + 0.5 = 1.0$.",
      "handbook": "Trigonometry — common-angle values", "references": "Ctrl-F: Trigonometric" },

    { "id": "D1-Q06", "set": "A", "type": "MCQ", "concept": "Distance formula",
      "stem": "The distance between points (1, 2) and (4, 6) is:",
      "equations": ["$d = \\sqrt{\\Delta x^{2} + \\Delta y^{2}}$"],
      "options": ["3", "4", "5", "7"], "answer": 2,
      "solution": "$d = \\sqrt{(4-1)^{2}+(6-2)^{2}} = \\sqrt{9+16} = \\sqrt{25} = 5$.",
      "handbook": "Analytic Geometry — distance formula", "references": "Ctrl-F: Distance" },

    { "id": "D1-Q07", "set": "A", "type": "MCQ", "concept": "Equation of a line",
      "stem": "A line passes through (0, 1) and (2, 5). Its equation is:",
      "equations": ["$m = \\dfrac{\\Delta y}{\\Delta x},\\quad y = mx + b$"],
      "options": ["y = 2x + 1", "y = x + 1", "y = 2x − 1", "y = 3x + 1"], "answer": 0,
      "solution": "$m = \\dfrac{5-1}{2-0} = 2;\\ b = 1$, so $y = 2x + 1$.",
      "handbook": "Analytic Geometry — straight line", "references": "Ctrl-F: Straight Line" },

    { "id": "D1-Q08", "set": "A", "type": "MCQ", "concept": "Circle (conic)",
      "stem": "The equation (x − 2)² + (y + 1)² = 25 is a circle with center and radius:",
      "equations": ["$(x-h)^{2}+(y-k)^{2}=r^{2}$"],
      "options": ["center (2, −1), r = 25", "center (−2, 1), r = 5", "center (2, −1), r = 5", "center (−2, 1), r = 25"], "answer": 2,
      "solution": "Standard form gives center $(2,-1)$ and $r = \\sqrt{25} = 5$.",
      "handbook": "Analytic Geometry — conic sections", "references": "Ctrl-F: Conic" },

    { "id": "D1-Q09", "set": "A", "type": "MCQ", "concept": "Polynomial derivative",
      "stem": "For f(x) = 3x³ − 2x² + x, the derivative f′(2) =",
      "equations": ["$\\dfrac{d}{dx}x^{n} = n x^{n-1}$"],
      "options": ["17", "23", "29", "35"], "answer": 2,
      "solution": "$f'(x) = 9x^{2}-4x+1;\\ f'(2) = 36-8+1 = 29$.",
      "handbook": "Differential Calculus — derivatives", "references": "Ctrl-F: Derivative" },

    { "id": "D1-Q10", "set": "A", "type": "MCQ", "concept": "Definite integral",
      "stem": "Evaluate ∫₀⁴ (2x + 3) dx.",
      "equations": ["$\\int (2x+3)\\,dx = x^{2}+3x$"],
      "options": ["20", "24", "28", "32"], "answer": 2,
      "solution": "$[x^{2}+3x]_0^4 = (16+12) - 0 = 28$.",
      "handbook": "Integral Calculus", "references": "Ctrl-F: Integral Calculus" },

    { "id": "D1-Q11", "set": "A", "type": "MCQ", "concept": "Integral of 1/x",
      "stem": "Evaluate ∫₁³ (1/x) dx.",
      "equations": ["$\\int \\dfrac{dx}{x} = \\ln|x|$"],
      "options": ["0.48", "1.10", "2.00", "3.00"], "answer": 1,
      "solution": "$[\\ln x]_1^3 = \\ln 3 - \\ln 1 = 1.099 \\approx 1.10$.",
      "handbook": "Integral Calculus — standard integrals", "references": "Ctrl-F: Integral Calculus" },

    { "id": "D1-Q12", "set": "A", "type": "MCQ", "concept": "Maxima / minima",
      "stem": "The function f(x) = x² − 6x + 5 has a minimum value of:",
      "equations": ["Vertex at $x = -\\dfrac{b}{2a}$"],
      "options": ["−4", "0", "3", "5"], "answer": 0,
      "solution": "$x = \\dfrac{6}{2} = 3;\\ f(3) = 9-18+5 = -4$ (minimum since $a>0$).",
      "handbook": "Differential Calculus — maxima/minima", "references": "Ctrl-F: Minima" },

    { "id": "D1-Q13", "set": "A", "type": "MCQ", "concept": "First-order half-life",
      "stem": "A contaminant decays by first order, dC/dt = −kC, with k = 0.10 day⁻¹. Its half-life is closest to:",
      "equations": ["$t_{1/2} = \\dfrac{0.693}{k}$"],
      "options": ["5.0 days", "6.9 days", "10 days", "14 days"], "answer": 1,
      "solution": "$t_{1/2} = \\dfrac{0.693}{0.10} = 6.93\\ \\mathrm{days}$. (Same form drives BOD decay, disinfection, radioactive decay.)",
      "handbook": "Mathematics — differential equations / decay", "references": "Ctrl-F: Half-Life" },

    { "id": "D1-Q14", "set": "A", "type": "MCQ", "concept": "Numerical integration",
      "stem": "Using the trapezoidal rule with two equal intervals (h = 1), estimate ∫₀² x² dx.",
      "equations": ["$\\dfrac{h}{2}\\left[f_0 + 2f_1 + f_2\\right]$"],
      "options": ["2.0", "2.67", "3.0", "4.0"], "answer": 2,
      "solution": "$\\dfrac{1}{2}[0 + 2(1) + 4] = 3.0$ (exact is 2.67; the rule overestimates a convex curve).",
      "handbook": "Numerical Methods — numerical integration", "references": "Ctrl-F: Trapezoidal" },

    { "id": "D1-Q15", "set": "A", "type": "MCQ", "concept": "Limits",
      "stem": "The limit lim(x→0) (sin x)/x is:",
      "equations": ["$\\lim_{x\\to 0}\\dfrac{\\sin x}{x} = 1$"],
      "options": ["0", "1", "∞", "undefined"], "answer": 1,
      "solution": "A standard limit: $\\dfrac{\\sin x}{x} \\to 1$ as $x \\to 0$.",
      "handbook": "Differential Calculus — limits / L'Hôpital", "references": "Ctrl-F: L'Hospital" },

    { "id": "D1-Q16", "set": "A", "type": "MCQ", "concept": "Vector dot product",
      "stem": "The dot product (2, 3, 1) · (1, −1, 4) =",
      "equations": ["$\\mathbf{A}\\cdot\\mathbf{B} = \\textstyle\\sum A_i B_i$"],
      "options": ["0", "3", "7", "9"], "answer": 1,
      "solution": "$2(1) + 3(-1) + 1(4) = 2 - 3 + 4 = 3$.",
      "handbook": "Vectors — dot product", "references": "Ctrl-F: Dot Product" },

    { "id": "D1-Q17", "set": "A", "type": "MCQ", "concept": "2×2 determinant",
      "stem": "The determinant |2 1; 3 4| =",
      "equations": ["$\\det\\begin{vmatrix}a&b\\\\c&d\\end{vmatrix} = ad - bc$"],
      "options": ["5", "8", "11", "−5"], "answer": 0,
      "solution": "$(2)(4) - (1)(3) = 8 - 3 = 5$.",
      "handbook": "Matrices — determinants", "references": "Ctrl-F: Determinant" },

    { "id": "D1-Q18", "set": "A", "type": "MCQ", "concept": "Newton-Raphson",
