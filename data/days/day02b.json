  "topic": "Fluid Mechanics I",
  "questions": [
    { "id": "D2B-Q01", "set": "B", "type": "MCQ", "concept": "Kinematic viscosity",
      "stem": "A fluid has dynamic viscosity μ = 1.5 × 10⁻³ Pa·s and density 850 kg/m³. Its kinematic viscosity is most nearly:",
      "equations": ["$\\nu = \\dfrac{\\mu}{\\rho}$"],
      "options": ["1.76 × 10⁻⁶ m²/s", "1.28 × 10⁻³ m²/s", "5.67 × 10⁵ m²/s", "1.76 × 10⁻³ m²/s"], "answer": 0,
      "solution": "$\\nu = \\dfrac{1.5\\times10^{-3}}{850} = 1.76\\times10^{-6}\\ \\mathrm{m^2/s}$.",
      "handbook": "Fluid Properties — kinematic viscosity (p. 181)", "references": "Ctrl-F: Kinematic" },

    { "id": "D2B-Q02", "set": "B", "type": "MCQ", "concept": "Specific weight",
      "stem": "Seawater has a specific gravity of 1.03. Its specific weight is most nearly:",
      "equations": ["$\\gamma = SG\\,\\gamma_w$"],
      "options": ["9.81 kN/m³", "10.1 kN/m³", "1.03 kN/m³", "10.1 N/m³"], "answer": 1,
      "solution": "$\\gamma = (1.03)(9.81) = 10.1\\ \\mathrm{kN/m^3}$.",
      "handbook": "Fluid Properties — specific weight (p. 181)", "references": "Ctrl-F: Specific Weight" },

    { "id": "D2B-Q03", "set": "B", "type": "MCQ", "concept": "Manometry",
      "stem": "A simple mercury manometer (SG = 13.6) open to the atmosphere shows a column height of 150 mm. The applied gauge pressure is most nearly:",
      "equations": ["$p = SG\\,\\gamma_w\\,h$"],
      "options": ["2.04 kPa", "20.0 kPa", "14.7 kPa", "1.47 kPa"], "answer": 1,
      "solution": "$p = (13.6)(9810)(0.150) = 20{,}012\\ \\mathrm{Pa} \\approx 20.0\\ \\mathrm{kPa}$.",
      "handbook": "Fluid Mechanics — manometry (p. 183)", "references": "Ctrl-F: Manometer" },

    { "id": "D2B-Q04", "set": "B", "type": "MCQ", "concept": "Layered fluids",
      "stem": "A tank holds a 2.0 m layer of oil (SG = 0.80) floating on a 3.0 m layer of water. The gauge pressure at the bottom is most nearly:",
      "equations": ["$p = \\textstyle\\sum \\gamma_i h_i$"],
      "options": ["45.1 kPa", "39.2 kPa", "49.1 kPa", "29.4 kPa"], "answer": 0,
      "solution": "$p = (0.80)(9.81)(2.0) + (9.81)(3.0) = 15.70 + 29.43 = 45.1\\ \\mathrm{kPa}$.",
      "handbook": "Fluid Statics — layered fluids (p. 181)", "references": "Ctrl-F: Specific Weight" },

    { "id": "D2B-Q05", "set": "B", "type": "MCQ", "concept": "Hydrostatic pressure",
      "stem": "The gauge pressure at a depth of 20 m in seawater (SG = 1.025) is most nearly:",
      "equations": ["$p = SG\\,\\gamma_w\\,h$"],
      "options": ["196 kPa", "201 kPa", "210 kPa", "20.1 kPa"], "answer": 1,
      "solution": "$p = (1.025)(9.81)(20) = 201\\ \\mathrm{kPa}$.",
      "handbook": "Fluid Mechanics — p = γh (p. 181)", "references": "Ctrl-F: Specific Gravity" },

    { "id": "D2B-Q06", "set": "B", "type": "MCQ", "concept": "Force on submerged plane",
      "stem": "A vertical square gate 1.0 m × 1.0 m has its top edge 2.0 m below the water surface. The resultant hydrostatic force on the gate is most nearly:",
      "equations": ["$F_R = \\gamma\\,\\bar h\\,A$"],
      "options": ["19.6 kN", "24.5 kN", "9.81 kN", "29.4 kN"], "answer": 1,
      "solution": "$\\bar h = 2.0+0.5 = 2.5\\ \\mathrm{m},\\ A = 1\\ \\mathrm{m^2}$. $F_R = (9.81)(2.5)(1) = 24.5\\ \\mathrm{kN}$.",
      "handbook": "Forces on Submerged Surfaces (p. 184)", "references": "Ctrl-F: Center of Pressure" },

    { "id": "D2B-Q07", "set": "B", "type": "MCQ", "concept": "Center of pressure",
      "stem": "For the previous gate (1 m × 1 m, top 2 m deep), the depth of the center of pressure below the surface is most nearly:",
      "equations": ["$y_{cp} = \\bar y + \\dfrac{I_{xc}}{\\bar y A},\\quad I_{xc} = \\dfrac{bh^{3}}{12}$"],
      "options": ["2.50 m", "2.53 m", "2.83 m", "3.03 m"], "answer": 1,
      "solution": "$I_{xc} = \\dfrac{(1)(1)^3}{12} = 0.0833;\\ y_{cp} = 2.5 + \\dfrac{0.0833}{(2.5)(1)} = 2.53\\ \\mathrm{m}$.",
      "handbook": "Center of Pressure (p. 184)", "references": "Ctrl-F: Center of Pressure" },

    { "id": "D2B-Q08", "set": "B", "type": "MCQ", "concept": "Flotation",
      "stem": "A block of wood of specific gravity 0.60 floats freely in water. The fraction of its volume that is submerged is most nearly:",
      "equations": ["submerged fraction $= SG$"],
      "options": ["40%", "60%", "80%", "100%"], "answer": 1,
      "solution": "A freely floating body displaces its own weight, so $\\dfrac{V_{sub}}{V} = SG = 0.60$ (60%).",
      "handbook": "Buoyancy / flotation (p. 184)", "references": "Ctrl-F: Flotation" },

    { "id": "D2B-Q09", "set": "B", "type": "MCQ", "concept": "Pascal's law",
      "stem": "A hydraulic lift has piston diameters of 50 mm (input) and 300 mm (output). An input force of 200 N can support an output load of most nearly:",
      "equations": ["$F_2 = F_1\\left(\\dfrac{D_2}{D_1}\\right)^{2}$"],
      "options": ["1200 N", "7200 N", "2400 N", "33 N"], "answer": 1,
      "solution": "$F_2 = 200\\left(\\dfrac{300}{50}\\right)^{2} = 200(36) = 7200\\ \\mathrm{N}$.",
      "handbook": "Pascal's law / hydraulic press (fundamental — Pascal's principle; relation given in stem, not a printed Handbook v10.6 formula)", "references": "Ctrl-F: Pascal" },

    { "id": "D2B-Q10", "set": "B", "type": "Numeric", "concept": "Continuity (velocity)",
      "stem": "Water flows at Q = 0.030 m³/s through a pipe of inside diameter 150 mm. Determine the mean velocity, in m/s.",
      "equations": ["$V = \\dfrac{Q}{A},\\quad A = \\dfrac{\\pi}{4}D^{2}$"],
      "answer": "1.70 m/s",
      "solution": "$A = \\dfrac{\\pi}{4}(0.150)^{2} = 0.01767\\ \\mathrm{m^2};\\ V = \\dfrac{0.030}{0.01767} = 1.70\\ \\mathrm{m/s}$.",
      "handbook": "Continuity Equation, Q = AV (p. 185)", "references": "Ctrl-F: Continuity Equation" },

    { "id": "D2B-Q11", "set": "B", "type": "MCQ", "concept": "Branching continuity",
      "stem": "A 300 mm pipe carrying water at 2.0 m/s splits into two identical 150 mm pipes that share the flow equally. The velocity in each branch is most nearly:",
      "equations": ["$\\textstyle\\sum Q_{in} = \\sum Q_{out}$"],
      "options": ["2.0 m/s", "4.0 m/s", "1.0 m/s", "8.0 m/s"], "answer": 1,
      "solution": "$Q = \\dfrac{\\pi}{4}(0.30)^2(2.0) = 0.1414\\ \\mathrm{m^3/s}$; each branch carries 0.0707 through $A = 0.01767\\ \\mathrm{m^2}$: $V = 4.0\\ \\mathrm{m/s}$.",
      "handbook": "Continuity — branching flow (p. 185)", "references": "Ctrl-F: Continuity Equation" },

    { "id": "D2B-Q12", "set": "B", "type": "MCQ", "concept": "Mass flow rate",
      "stem": "Air (ρ = 1.2 kg/m³) flows at 10 m/s through a 0.5 m × 0.5 m duct. The mass flow rate is most nearly:",
      "equations": ["$\\dot m = \\rho A V$"],
      "options": ["3.0 kg/s", "2.5 kg/s", "6.0 kg/s", "1.5 kg/s"], "answer": 0,
      "solution": "$\\dot m = (1.2)(0.25)(10) = 3.0\\ \\mathrm{kg/s}$.",
      "handbook": "Continuity — mass flow rate (p. 185)", "references": "Ctrl-F: Mass flow" },

    { "id": "D2B-Q13", "set": "B", "type": "MCQ", "concept": "Orifice (Torricelli)",
      "stem": "Water discharges from an orifice 9.0 m below the free surface of a large open tank. Neglecting losses, the jet velocity is most nearly:",
      "equations": ["$v = \\sqrt{2gh}$"],
      "options": ["13.3 m/s", "9.39 m/s", "18.8 m/s", "6.64 m/s"], "answer": 0,
      "solution": "$v = \\sqrt{2(9.81)(9.0)} = \\sqrt{176.6} = 13.3\\ \\mathrm{m/s}$.",
      "handbook": "Bernoulli/Energy — orifice discharge (p. 190)", "references": "Ctrl-F: Orifice" },

    { "id": "D2B-Q14", "set": "B", "type": "MCQ", "concept": "Bernoulli (horizontal)",
      "stem": "Water flows in a horizontal pipe. At point 1, V₁ = 1.0 m/s and p₁ = 150 kPa; the pipe narrows so that V₂ = 4.0 m/s. Neglecting losses, p₂ is most nearly:",
      "equations": ["$p_2 = p_1 + \\tfrac{1}{2}\\rho(V_1^{2}-V_2^{2})$"],
      "options": ["142.5 kPa", "157.5 kPa", "135.0 kPa", "150.0 kPa"], "answer": 0,
      "solution": "$p_2 = 150{,}000 + \\tfrac{1}{2}(1000)(1^2-4^2) = 150{,}000 - 7{,}500 = 142.5\\ \\mathrm{kPa}$.",
      "handbook": "Bernoulli Equation (p. 185)", "references": "Ctrl-F: Bernoulli" },

    { "id": "D2B-Q15", "set": "B", "type": "MCQ", "concept": "Velocity head",
      "stem": "Water leaves a nozzle at 15 m/s. The corresponding velocity head is most nearly:",
      "equations": ["$\\dfrac{V^{2}}{2g}$"],
      "options": ["11.5 m", "1.53 m", "7.65 m", "22.9 m"], "answer": 0,
      "solution": "$\\dfrac{V^{2}}{2g} = \\dfrac{15^{2}}{2(9.81)} = \\dfrac{225}{19.62} = 11.5\\ \\mathrm{m}$.",
      "handbook": "Bernoulli/Energy — velocity head (p. 187)", "references": "Ctrl-F: Velocity Head" },

    { "id": "D2B-Q16", "set": "B", "type": "MCQ", "concept": "Bernoulli (elevation)",
      "stem": "Water flows up a constant-diameter vertical pipe. At the bottom p₁ = 250 kPa; the top is 10 m higher with unchanged velocity. Neglecting losses, the pressure at the top is most nearly:",
      "equations": ["$p_2 = p_1 - \\gamma\\,\\Delta z$"],
      "options": ["151.9 kPa", "250 kPa", "348.1 kPa", "200 kPa"], "answer": 0,
      "solution": "$p_2 = 250{,}000 - (9810)(10) = 151{,}900\\ \\mathrm{Pa} \\approx 151.9\\ \\mathrm{kPa}$.",
      "handbook": "Bernoulli/Energy — elevation head (p. 185)", "references": "Ctrl-F: Bernoulli" },

    { "id": "D2B-Q17", "set": "B", "type": "MCQ", "concept": "Pitot-static",
      "stem": "A pitot-static tube in a water flow reads a stagnation-minus-static pressure difference of 5.0 kPa. The flow velocity is most nearly:",
      "equations": ["$V = \\sqrt{\\dfrac{2\\,\\Delta p}{\\rho}}$"],
      "options": ["3.16 m/s", "10.0 m/s", "2.24 m/s", "1.58 m/s"], "answer": 0,
      "solution": "$V = \\sqrt{\\dfrac{2(5000)}{1000}} = \\sqrt{10} = 3.16\\ \\mathrm{m/s}$.",
      "handbook": "Fluid Mechanics — pitot tube / stagnation (p. 200)", "references": "Ctrl-F: Pitot" },

    { "id": "D2B-Q18", "set": "B", "type": "MCQ", "concept": "Reynolds number",
      "stem": "Oil (ρ = 900 kg/m³, μ = 0.018 Pa·s) flows at 1.2 m/s in an 80 mm pipe. The Reynolds number is most nearly:",
      "equations": ["$\\mathrm{Re} = \\dfrac{\\rho V D}{\\mu}$"],
      "options": ["4,800", "48,000", "480", "960"], "answer": 0,
      "solution": "$\\mathrm{Re} = \\dfrac{(900)(1.2)(0.080)}{0.018} = 4800$.",
      "handbook": "Reynolds Number (p. 186)", "references": "Ctrl-F: Reynolds Number" },

    { "id": "D2B-Q19", "set": "B", "type": "MCQ", "concept": "Reynolds + regime",
      "stem": "Water (ν = 1.0 × 10⁻⁶ m²/s) flows at 0.05 m/s in a 20 mm pipe. The Reynolds number and flow regime are:",
      "equations": ["$\\mathrm{Re} = \\dfrac{VD}{\\nu}$"],
      "options": ["1,000, laminar", "1,000, turbulent", "2,000, laminar", "20,000, turbulent"], "answer": 0,
      "solution": "$\\mathrm{Re} = \\dfrac{(0.05)(0.020)}{1.0\\times10^{-6}} = 1000$; since Re < 2100, laminar.",
      "handbook": "Reynolds Number — flow regimes (p. 186)", "references": "Ctrl-F: Reynolds Number" },

    { "id": "D2B-Q20", "set": "B", "type": "Numeric", "concept": "Hydraulic diameter",
      "stem": "A rectangular duct 0.40 m × 0.20 m flows completely full. Determine the hydraulic diameter, in m.",
      "equations": ["$D_H = \\dfrac{4A}{P}$"],
      "answer": "0.267 m",
      "solution": "$D_H = \\dfrac{4(0.40\\times0.20)}{2(0.40+0.20)} = \\dfrac{0.32}{1.2} = 0.267\\ \\mathrm{m}$.",
      "handbook": "Reynolds Number — hydraulic diameter (p. 188)", "references": "Ctrl-F: Hydraulic Diameter" }
  ]
}
