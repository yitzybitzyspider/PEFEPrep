{
  "day": 3,
  "date": "2026-06-19",
  "topic": "Fluid Mechanics II / Pipe Flow",
  "questions": [
    { "id": "D3-Q01", "set": "A", "type": "MCQ", "concept": "Darcy-Weisbach (concept)",
      "stem": "In the Darcy-Weisbach equation, friction head loss in a pipe is proportional to which power of the average velocity?",
      "equations": ["$h_f = f\\dfrac{L}{D}\\dfrac{V^{2}}{2g}$"],
      "options": ["$V$", "$V^{2}$", "$1/V$", "$V^{3}$"], "answer": 1,
      "solution": "Darcy-Weisbach contains $V^{2}$, so $h_f \\propto V^{2}$.",
      "handbook": "Consequences of Fluid Flow — Head Loss (Darcy-Weisbach) (p. 187)", "references": "Ctrl-F: Darcy-Weisbach" },

    { "id": "D3-Q02", "set": "A", "type": "MCQ", "concept": "Darcy-Weisbach (calc)",
      "stem": "Water flows at V = 2.0 m/s through a 150 mm (0.15 m) pipe of length 200 m with Darcy friction factor f = 0.02. The friction head loss is closest to:",
      "equations": ["$h_f = f\\dfrac{L}{D}\\dfrac{V^{2}}{2g}$"],
      "options": ["2.7 m", "5.4 m", "10.9 m", "0.54 m"], "answer": 1,
      "solution": "$h_f = 0.02\\cdot\\dfrac{200}{0.15}\\cdot\\dfrac{2.0^{2}}{2(9.81)} = 0.02(1333)(0.2039) = 5.44\\ \\mathrm{m}$.",
      "handbook": "Consequences of Fluid Flow — Head Loss (Darcy-Weisbach) (p. 187)", "references": "Ctrl-F: Darcy-Weisbach" },

    { "id": "D3-Q03", "set": "A", "type": "MCQ", "concept": "Laminar friction factor",
      "stem": "For fully developed laminar flow with Re = 1800, the Darcy friction factor is:",
      "equations": ["$f = \\dfrac{64}{\\mathrm{Re}}$"],
      "options": ["0.018", "0.0356", "0.064", "0.32"], "answer": 1,
      "solution": "$f = \\dfrac{64}{1800} = 0.0356$.",
      "handbook": "Moody/Darcy/Stanton Diagram (laminar line f = 64/Re) (p. 206)", "references": "Ctrl-F: Friction Factor" },

    { "id": "D3-Q04", "set": "A", "type": "MCQ", "concept": "Moody — fully rough zone",
      "stem": "In the fully rough (complete-turbulence) zone of the Moody diagram, the friction factor depends on:",
      "equations": ["$f = f(\\mathrm{Re},\\ \\varepsilon/D)$"],
      "options": ["Reynolds number only", "relative roughness ε/D only", "both Re and ε/D", "neither"], "answer": 1,
      "solution": "In the fully rough zone the Moody curves are horizontal: $f$ is set by $\\varepsilon/D$ alone, independent of Re.",
      "handbook": "Moody, Darcy, or Stanton Friction Factor Diagram (p. 206)", "references": "Ctrl-F: Moody" },

    { "id": "D3-Q05", "set": "A", "type": "MCQ", "concept": "Hazen-Williams (calc)",
      "stem": "Using Hazen-Williams (SI), water flows in a 0.30 m pipe with C = 130 and energy slope S = 0.005. The velocity is closest to:",
      "equations": ["$V = k_1 C R^{0.63} S^{0.54}$", "$R = D/4$,  $k_1 = 0.849$ (SI)"],
      "options": ["0.62 m/s", "1.23 m/s", "2.47 m/s", "3.7 m/s"], "answer": 1,
      "solution": "$R = 0.075\\ \\mathrm{m}$. $V = 0.849(130)(0.075)^{0.63}(0.005)^{0.54} = 110.4(0.187)(0.0598) = 1.23\\ \\mathrm{m/s}$.",
      "handbook": "Hazen-Williams Equation (p. 189)", "references": "Ctrl-F: Hazen-Williams" },

    { "id": "D3-Q06", "set": "A", "type": "MCQ", "concept": "Minor loss (single fitting)",
      "stem": "A gate valve (C = 0.2) carries water at V = 2.5 m/s. The minor head loss across the valve is closest to:",
      "equations": ["$h_{f,\\text{fitting}} = C\\dfrac{V^{2}}{2g}$"],
      "options": ["0.032 m", "0.064 m", "0.16 m", "0.64 m"], "answer": 1,
      "solution": "$h = 0.2\\cdot\\dfrac{2.5^{2}}{2(9.81)} = 0.2(0.3186) = 0.064\\ \\mathrm{m}$.",
      "handbook": "Minor Losses in Pipe Fittings (p. 187)", "references": "Ctrl-F: Minor Losses" },

    { "id": "D3-Q07", "set": "A", "type": "MCQ", "concept": "Pump fluid power",
      "stem": "A pump delivers Q = 0.04 m³/s of water against a total head of 25 m. The hydraulic (water) power added to the fluid is closest to:",
      "equations": ["$\\dot W_{fluid} = \\gamma Q H$"],
      "options": ["4.9 kW", "9.8 kW", "14.0 kW", "19.6 kW"], "answer": 1,
      "solution": "$\\dot W = (9.81)(0.04)(25) = 9.81\\ \\mathrm{kW}$.",
      "handbook": "Pump Power Equation (p. 197)", "references": "Ctrl-F: Fluid power" },

    { "id": "D3-Q08", "set": "A", "type": "MCQ", "concept": "Pump brake power",
      "stem": "For the pump in the previous problem (Q = 0.04 m³/s, H = 25 m), if the pump efficiency is 70%, the required brake (shaft) power is closest to:",
      "equations": ["$\\dot W_{brake} = \\dfrac{\\gamma Q H}{\\eta}$"],
      "options": ["6.9 kW", "9.8 kW", "14.0 kW", "20.0 kW"], "answer": 2,
      "solution": "$\\dot W_{brake} = \\dfrac{9.81}{0.70} = 14.0\\ \\mathrm{kW}$.",
      "handbook": "Pump Power / Efficiency (p. 197)", "references": "Ctrl-F: Efficiency" },

    { "id": "D3-Q09", "set": "A", "type": "MCQ", "concept": "Pumps in parallel",
      "stem": "Two identical pumps operated in parallel, compared with a single pump, primarily increase the:",
      "equations": ["Parallel: flows add at a given head"],
      "options": ["head delivered at a given flow", "flow delivered at a given head", "pump efficiency", "NPSH required"], "answer": 1,
      "solution": "Pumps in parallel add their flows at a common head — the combination delivers more flow. (Note: series/parallel combination is a concept, not an FE Handbook formula.)",
      "handbook": "Performance of Components (Pumps) — concept (p. 197)", "references": "Ctrl-F: Pump" },

    { "id": "D3-Q10", "set": "A", "type": "MCQ", "concept": "Affinity (scaling) laws",
      "stem": "A centrifugal pump running at 1,200 rpm produces 20 m of head. Using the affinity laws, if the speed is increased to 1,800 rpm, the head produced is closest to:",
      "equations": ["$\\dfrac{H_2}{H_1} = \\left(\\dfrac{N_2}{N_1}\\right)^{2}$"],
      "options": ["30 m", "45 m", "67.5 m", "13.3 m"], "answer": 1,
      "solution": "$H_2 = 20\\left(\\dfrac{1800}{1200}\\right)^{2} = 20(1.5)^{2} = 45\\ \\mathrm{m}$.",
      "handbook": "Performance of Components — Scaling/Affinity Laws (p. 199)", "references": "Ctrl-F: Affinity Laws" },

    { "id": "D3-Q11", "set": "A", "type": "MCQ", "concept": "Minor loss (sum of fittings)",
      "stem": "Water flows at V = 2.0 m/s through a section with two 90° elbows (C = 0.9 each) and a fully open globe valve (C = 10). The total minor (fitting) head loss is closest to:",
      "equations": ["$h = \\left(\\textstyle\\sum C\\right)\\dfrac{V^{2}}{2g}$"],
      "options": ["1.2 m", "2.4 m", "0.24 m", "4.8 m"], "answer": 1,
      "solution": "$\\sum C = 0.9+0.9+10 = 11.8$; $h = 11.8\\cdot\\dfrac{2.0^{2}}{2(9.81)} = 11.8(0.2039) = 2.41\\ \\mathrm{m}$.",
      "handbook": "Minor Losses in Pipe Fittings (p. 187)", "references": "Ctrl-F: Minor Losses" },

    { "id": "D3-Q12", "set": "A", "type": "MCQ", "concept": "Continuity (velocity)",
      "stem": "Water flows at Q = 0.10 m³/s in a 0.25 m pipe. The average velocity is closest to:",
      "equations": ["$V = \\dfrac{Q}{A},\\quad A = \\dfrac{\\pi}{4}D^{2}$"],
      "options": ["1.0 m/s", "2.0 m/s", "4.1 m/s", "0.5 m/s"], "answer": 1,
      "solution": "$A = \\dfrac{\\pi}{4}(0.25)^{2} = 0.0491\\ \\mathrm{m^2};\\ V = \\dfrac{0.10}{0.0491} = 2.04\\ \\mathrm{m/s}$.",
      "handbook": "Continuity Equation (Q = AV) (p. 185)", "references": "Ctrl-F: Continuity Equation" },

    { "id": "D3-Q13", "set": "A", "type": "MCQ", "concept": "Reynolds + regime",
      "stem": "Water (ν = 1.0 × 10⁻⁶ m²/s) flows at V = 1.5 m/s in a 0.10 m pipe. The Reynolds number and flow regime are:",
      "equations": ["$\\mathrm{Re} = \\dfrac{VD}{\\nu}$"],
      "options": ["1.5 × 10⁴, laminar", "1.5 × 10⁵, turbulent", "1.5 × 10⁵, laminar", "6.6 × 10⁵, turbulent"], "answer": 1,
      "solution": "$\\mathrm{Re} = \\dfrac{(1.5)(0.10)}{1.0\\times10^{-6}} = 1.5\\times10^{5}$. The Handbook classifies Re > 10,000 as fully turbulent, so turbulent.",
      "handbook": "Reynolds Number (p. 186)", "references": "Ctrl-F: Reynolds Number" },

    { "id": "D3-Q14", "set": "A", "type": "MCQ", "concept": "Total head loss (major + minor)",
      "stem": "A 0.10 m pipe, 100 m long, f = 0.02, carries water at V = 2.0 m/s with a sharp entrance (C = 0.5) and an exit (C = 1.0). The total head loss (major + minor) is closest to:",
      "equations": ["$h_L = f\\dfrac{L}{D}\\dfrac{V^{2}}{2g} + \\left(\\textstyle\\sum C\\right)\\dfrac{V^{2}}{2g}$"],
      "options": ["4.1 m", "4.4 m", "0.31 m", "8.2 m"], "answer": 1,
      "solution": "Major: $0.02\\cdot\\dfrac{100}{0.1}\\cdot0.2039 = 4.08\\ \\mathrm{m}$. Minor: $(0.5+1.0)(0.2039) = 0.31\\ \\mathrm{m}$. Total $= 4.39\\ \\mathrm{m}$.",
      "handbook": "Total Head Loss (major + minor) (p. 187)", "references": "Ctrl-F: Minor Losses" },

    { "id": "D3-Q15", "set": "A", "type": "MCQ", "concept": "Pump power (lift + friction)",
      "stem": "A pump lifts water a static height of 15 m while overcoming 8 m of friction loss at Q = 0.03 m³/s. The hydraulic power required is closest to:",
      "equations": ["$\\dot W = \\gamma Q H,\\quad H = H_{static} + h_L$"],
      "options": ["4.4 kW", "6.8 kW", "2.4 kW", "9.1 kW"], "answer": 1,
      "solution": "$H = 15 + 8 = 23\\ \\mathrm{m};\\ \\dot W = (9.81)(0.03)(23) = 6.77\\ \\mathrm{kW}$.",
      "handbook": "Pump Power Equation (p. 197)", "references": "Ctrl-F: Fluid power" },

    { "id": "D3-Q16", "set": "A", "type": "Numeric", "concept": "Pump brake power",
      "stem": "A pump delivers Q = 0.05 m³/s of water at a head of 40 m with an efficiency of 80%. Determine the required brake power, in kW.",
      "equations": ["$\\dot W_{brake} = \\dfrac{\\gamma Q H}{\\eta}$"],
      "answer": "24.5 kW",
      "solution": "$\\dot W_{brake} = \\dfrac{(9.81)(0.05)(40)}{0.80} = \\dfrac{19.62}{0.80} = 24.5\\ \\mathrm{kW}$.",
      "handbook": "Pump Power / Efficiency (p. 197)", "references": "Ctrl-F: Efficiency" },

    { "id": "D3-Q17", "set": "A", "type": "MCQ", "concept": "NPSH / cavitation",
      "stem": "To prevent cavitation at a pump suction, the design requirement is:",
      "equations": ["$NPSH_A > NPSH_R$"],
      "options": ["$NPSH_A < NPSH_R$", "$NPSH_A > NPSH_R$", "$NPSH_A = 0$", "$p_{vapor} > p_{atm}$"], "answer": 1,
      "solution": "Cavitation is avoided when available NPSH exceeds the required value: $NPSH_A > NPSH_R$.",
      "handbook": "NPSH / Cavitation (p. 196)", "references": "Ctrl-F: Net Positive Suction" },

    { "id": "D3-Q18", "set": "A", "type": "MCQ", "concept": "Pressure drop from head",
      "stem": "A friction head loss of 5.0 m of water corresponds to a pressure drop of approximately:",
      "equations": ["$\\Delta p = \\gamma h_f$"],
      "options": ["5.0 kPa", "49 kPa", "9.8 kPa", "490 kPa"], "answer": 1,
      "solution": "$\\Delta p = (9.81\\ \\mathrm{kN/m^3})(5.0\\ \\mathrm{m}) = 49.1\\ \\mathrm{kPa}$.",
      "handbook": "Pressure Head (p = γh) (p. 181)", "references": "Ctrl-F: Pressure Head" },

    { "id": "D3-Q19", "set": "A", "type": "MCQ", "concept": "Relative roughness",
      "stem": "A commercial steel pipe has absolute roughness ε = 0.045 mm and diameter D = 100 mm. Its relative roughness ε/D is:",
      "equations": ["$\\dfrac{\\varepsilon}{D}$"],
      "options": ["0.00045", "0.0045", "0.45", "0.045"], "answer": 0,
      "solution": "$\\dfrac{\\varepsilon}{D} = \\dfrac{0.045\\ \\mathrm{mm}}{100\\ \\mathrm{mm}} = 0.00045$.",
      "handbook": "Relative Roughness / Moody Diagram (p. 206)", "references": "Ctrl-F: Relative Roughness" },

    { "id": "D3-Q20", "set": "A", "type": "MCQ", "concept": "Hazen-Williams validity",
      "stem": "The Hazen-Williams equation is most appropriate for:",
      "equations": ["$V = k_1 C R^{0.63} S^{0.54}$  (empirical)"],
      "options": ["any fluid in any regime", "water in turbulent flow", "laminar flow only", "compressible gas flow"], "answer": 1,
      "solution": "Hazen-Williams is empirical, calibrated for water at ordinary temperatures in turbulent flow only.",
      "handbook": "Hazen-Williams Equation (p. 189)", "references": "Ctrl-F: Hazen-Williams" },

    { "id": "D3-Q21", "set": "A", "type": "Numeric", "concept": "Darcy-Weisbach (numeric)",
      "stem": "Water (Q = 0.06 m³/s) flows in a 0.20 m pipe, 500 m long, with f = 0.018. Determine the Darcy-Weisbach friction head loss, in meters.",
      "equations": ["$V = \\dfrac{Q}{A},\\quad h_f = f\\dfrac{L}{D}\\dfrac{V^{2}}{2g}$"],
      "answer": "8.4 m",
      "solution": "$A = \\dfrac{\\pi}{4}(0.20)^{2} = 0.0314\\ \\mathrm{m^2};\\ V = \\dfrac{0.06}{0.0314} = 1.91\\ \\mathrm{m/s}$. $h_f = 0.018\\cdot\\dfrac{500}{0.20}\\cdot\\dfrac{1.91^{2}}{2(9.81)} = 0.018(2500)(0.1859) = 8.37\\ \\mathrm{m}$.",
      "handbook": "Head Loss (Darcy-Weisbach) + Continuity (p. 187)", "references": "Ctrl-F: Darcy-Weisbach" }
  ]
}
