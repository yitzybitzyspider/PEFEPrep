    {
      "id": "DEMO-FM-04",
      "topic": "Fluid Mechanics",
      "type": "MCQ",
      "concept": "Darcy-Weisbach head loss",
      "stem": "A 100 m pipe (D = 0.10 m) carries water at 2.0 m/s with a Darcy friction factor f = 0.02. Using g = 9.81 m/s², the friction head loss is closest to:",
      "equations": ["$h_f = f\\,\\dfrac{L}{D}\\,\\dfrac{V^{2}}{2g}$  (Darcy-Weisbach)"],
      "options": ["2.04 m", "4.08 m", "8.15 m", "0.41 m"],
      "answer": 1,
      "steps": [
        "Darcy-Weisbach: $h_f = f\\dfrac{L}{D}\\dfrac{V^{2}}{2g}$.",
        "$\\dfrac{L}{D} = \\dfrac{100}{0.10} = 1000$ and $\\dfrac{V^{2}}{2g} = \\dfrac{2.0^{2}}{2(9.81)} = 0.2039$.",
        "$h_f = (0.02)(1000)(0.2039) = 4.08\\ \\mathrm{m}$."
      ],
      "solution": "$h_f = f\\dfrac{L}{D}\\dfrac{V^{2}}{2g} = (0.02)(1000)(0.2039) = 4.08\\ \\mathrm{m}$.",
      "handbook": "Fluid Mechanics — Darcy-Weisbach Equation",
      "references": "FE Handbook: Darcy-Weisbach Equation"
    },
