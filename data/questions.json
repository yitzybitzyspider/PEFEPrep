    {
      "id": "DEMO-FM-06",
      "topic": "Fluid Mechanics",
      "type": "MCQ",
      "concept": "Hydraulic radius of a full circular pipe",
      "stem": "For a circular pipe flowing full, the hydraulic radius R (= area / wetted perimeter) equals:",
      "equations": ["$R_H = \\dfrac{A}{P}$", "Full circle: $A=\\dfrac{\\pi D^{2}}{4}$, $P=\\pi D$"],
      "options": ["D", "D/2", "D/4", "4D"],
      "answer": 2,
      "steps": [
        "$R_H = \\dfrac{A}{P}$.",
        "$R_H = \\dfrac{\\pi D^{2}/4}{\\pi D} = \\dfrac{D}{4}$.",
        "Don’t confuse with hydraulic diameter $D_H = 4A/P = D$ (factor of 4 apart)."
      ],
      "solution": "$R_H = \\dfrac{A}{P} = \\dfrac{\\pi D^{2}/4}{\\pi D} = \\dfrac{D}{4}$.",
      "handbook": "Fluid Mechanics — Hydraulic Radius",
      "references": "FE Handbook: Hydraulic Radius"
    },
