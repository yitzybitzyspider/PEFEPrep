      "id": "DEMO-FM-01",
      "topic": "Fluid Mechanics",
      "type": "MCQ",
      "concept": "Continuity equation (Q = VA)",
      "stem": "Water flows through a circular pipe of inside diameter 0.10 m at an average velocity of 2.0 m/s. What is the volumetric flow rate Q?",
      "equations": ["$Q = V\\,A$  (continuity)", "$A = \\dfrac{\\pi D^{2}}{4}$  (circular area)"],
      "options": ["0.0157 m³/s", "0.0314 m³/s", "0.00785 m³/s", "0.157 m³/s"],
      "answer": 0,
      "steps": [
        "Governing relation: continuity, $Q = V\\,A$.",
        "Pipe area: $A = \\dfrac{\\pi D^{2}}{4} = \\dfrac{\\pi (0.10)^{2}}{4} = 7.85\\times10^{-3}\\ \\mathrm{m^{2}}$.",
        "$Q = V\\,A = (2.0)(7.85\\times10^{-3}) = 0.0157\\ \\mathrm{m^{3}/s}$."
      ],
      "solution": "$Q = VA = 2.0\\cdot\\dfrac{\\pi(0.10)^{2}}{4} = 0.0157\\ \\mathrm{m^{3}/s}$.",
      "handbook": "Fluid Mechanics — Continuity Equation",
      "references": "FE Handbook: Continuity Equation"
    },
    {
      "id": "DEMO-FM-02",
      "topic": "Fluid Mechanics",
      "type": "MCQ",
      "concept": "Reynolds number",
      "stem": "Water (kinematic viscosity ν = 1.0 × 10⁻⁶ m²/s) flows at 1.5 m/s through a 0.05 m diameter pipe. What is the Reynolds number?",
      "equations": ["$\\mathrm{Re} = \\dfrac{V D}{\\nu} = \\dfrac{\\rho V D}{\\mu}$"],
      "options": ["7,500", "75,000", "750,000", "3,000"],
      "answer": 1,
      "steps": [
        "Use $\\mathrm{Re} = \\dfrac{VD}{\\nu}$.",
        "Substitute: $\\dfrac{(1.5)(0.05)}{1.0\\times10^{-6}}$.",
        "$\\mathrm{Re} = 75{,}000$ (dimensionless)."
      ],
      "solution": "$\\mathrm{Re} = \\dfrac{VD}{\\nu} = \\dfrac{(1.5)(0.05)}{1.0\\times10^{-6}} = 75{,}000$.",
      "handbook": "Fluid Mechanics — Reynolds Number",
      "references": "FE Handbook: Reynolds Number"
    },
